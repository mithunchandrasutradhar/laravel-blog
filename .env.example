APP_NAME="Global Blog"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=blog
DB_PASSWORD=blogpassword
DB_ROOT_PASSWORD=rootpassword

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@globalblog.com"
MAIL_FROM_NAME="${APP_NAME}"

NGINX_PORT=80
NGINX_SSL_PORT=443
MYSQL_PORT=3306
REDIS_PORT=6379
PMA_PORT=8080

RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

GOOGLE_ANALYTICS_ID=
GOOGLE_ADSENSE_CLIENT=

VITE_APP_NAME="${APP_NAME}"
VITE_RECAPTCHA_SITE_KEY="${RECAPTCHA_SITE_KEY}"
